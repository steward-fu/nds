precision highp float;

uniform float frag_alpha;
uniform vec4 frag_screen;
varying vec2 frag_tex_coord;
uniform sampler2D frag_tex_sample;

#ifndef NATVIS_GIN
#define NATVIS_GIN 1.91
#endif
#ifndef NATVIS_GOUT
#define NATVIS_GOUT 1.91
#endif
#ifndef NATVIS_Y
#define NATVIS_Y 1.1
#endif
#ifndef NATVIS_I
#define NATVIS_I 1.1
#endif
#ifndef NATVIS_Q
#define NATVIS_Q 1.1
#endif

#define NDS_LUM 0.89
#define NDS_R 0.87
#define NDS_G 0.645
#define NDS_B 0.73
#define NDS_RG 0.10
#define NDS_RB 0.10
#define NDS_GR 0.255
#define NDS_GB 0.17
#define NDS_BR -0.125
#define NDS_BG 0.255

const mat3 NDSColourMatrix = mat3(NDS_R, NDS_RG, NDS_RB, NDS_GR, NDS_G, NDS_GB, NDS_BR, NDS_BG, NDS_B);
const mat3 RGBtoYIQ = mat3(0.299, 0.595716, 0.211456, 0.587, -0.274453, -0.522591, 0.114, -0.321263, 0.311135);
const mat3 YIQtoRGB = mat3(1.0, 1.0, 1.0, 0.95629572, -0.27212210, -1.10698902, 0.62102442, -0.64738060, 1.70461500);
const vec3 YIQ_lo = vec3(0.0, -0.595716, -0.522591);
const vec3 YIQ_hi = vec3(1.0,  0.595716,  0.522591);

#define u_texture_size_zw vec2(256.0, 192.0)

void main()
{
    vec2 precalc_texel = frag_tex_coord * u_texture_size_zw;
    vec2 precalc_scale = floor(frag_screen.xy / u_texture_size_zw) + 1.0;
    vec2 texel_floored = floor(precalc_texel);
    vec2 s = fract(precalc_texel);
    vec2 region_range = 0.5 - 0.5 / precalc_scale;

    vec2 center_dist = s - 0.5;
    vec2 f = (center_dist - clamp(center_dist, -region_range, region_range)) * precalc_scale + 0.5;

    vec2 mod_texel = texel_floored + f;

    vec3 colour = pow(texture2D(frag_tex_sample, mod_texel / u_texture_size_zw).rgb, vec3(NATVIS_GIN));

    colour = clamp(colour * NDS_LUM, 0.0, 1.0);
    colour = NDSColourMatrix * colour;

    colour = RGBtoYIQ * colour;
    colour = vec3(pow(colour.x, NATVIS_Y), colour.y * NATVIS_I, colour.z * NATVIS_Q);
    colour = clamp(colour, YIQ_lo, YIQ_hi);
    colour = YIQtoRGB * colour;
    colour = pow(colour, vec3(1.0 / NATVIS_GOUT));
 
    gl_FragColor = vec4(colour.bgr, 1.0);
}
